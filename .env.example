# TEED Hub Environment Variables Template
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ============================================================
# DJANGO SETTINGS
# ============================================================
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# ============================================================
# DATABASE (using SQLite for development)
# ============================================================
# For production, consider PostgreSQL, MySQL, etc.
DATABASE_URL=sqlite:///db.sqlite3

# ============================================================
# FRONTEND URL
# ============================================================
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================
# EMAIL CONFIGURATION - EMAIL PROVIDER SELECTION
# ============================================================
# Options: console (development), gmail, apple, sendgrid, mailgun
EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=noreply@teedhub.app

# ============================================================
# GMAIL CONFIGURATION (for EMAIL_PROVIDER=gmail)
# ============================================================
# 1. Enable 2-Step Verification on Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate app password for "Mail" and "Windows Computer"
# 4. Copy the 16-character password below (remove spaces)
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================================
# APPLE EMAIL CONFIGURATION (for EMAIL_PROVIDER=apple)
# ============================================================
# 1. Go to https://appleid.apple.com
# 2. Security → App-Specific Passwords → Generate
# 3. Copy the 16-character password below
APPLE_EMAIL=your-email@icloud.com
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ============================================================
# SENDGRID CONFIGURATION (for EMAIL_PROVIDER=sendgrid)
# ============================================================
# Get API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_api_key_here

# ============================================================
# MAILGUN CONFIGURATION (for EMAIL_PROVIDER=mailgun)
# ============================================================
# Get API key and domain from https://app.mailgun.com
MAILGUN_API_KEY=key-your_api_key_here
MAILGUN_DOMAIN=mg.yourdomain.com

# ============================================================
# EMAIL VERIFICATION SETTINGS
# ============================================================
EMAIL_VERIFICATION_TIMEOUT=24  # Hours before code expires
MAX_VERIFICATION_ATTEMPTS=5    # Max failed attempts before lockout
MAX_RECOVERY_ATTEMPTS=5        # Max account recovery attempts

# ============================================================
# SIGN IN WITH APPLE CONFIGURATION
# ============================================================
# Setup guide: TEED-documentation/APPLE_EMAIL_SETUP.md
# 1. Create App ID and Service ID in Apple Developer Console
# 2. Generate private key (.p8 file)
# 3. Get Team ID from developer.apple.com
APPLE_CLIENT_ID=com.teedhub.app.web
APPLE_TEAM_ID=ABCD12345E
APPLE_KEY_ID=ABCDEF1234
APPLE_SECRET=-----BEGIN PRIVATE KEY-----\nYour base64 encoded private key here\n-----END PRIVATE KEY-----
APPLE_APP_ID=com.teedhub.app

# ============================================================
# SOCIAL AUTH - GOOGLE
# ============================================================
# Setup: https://console.developers.google.com
# Create OAuth 2.0 credential (Web Application)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ============================================================
# SOCIAL AUTH - FACEBOOK
# ============================================================
# Setup: https://developers.facebook.com/apps/
# Create new app, add Facebook Login product
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret

# ============================================================
# JWT & SESSION SETTINGS
# ============================================================
# Token lifetime settings (in minutes/days)
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7

# ============================================================
# MOBILE API FLAG
# ============================================================
# Set to 'true' for React Native build
# Set to 'false' for React Web build
IS_MOBILE_API=false

# ============================================================
# AWS SERVICES (Optional - for production file storage)
# ============================================================
# Use S3 for storing user uploads instead of local disk
USE_S3=False
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_REGION_NAME=us-east-1
AWS_STORAGE_BUCKET_NAME=teedhub-uploads

# ============================================================
# SENTRY (Optional - for error tracking in production)
# ============================================================
SENTRY_DSN=https://key@sentry.io/project_id

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # Seconds

# ============================================================
# SECURITY HEADERS (Production)
# ============================================================
SECURE_SSL_REDIRECT=False  # Set to True in production with HTTPS
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=False  # Set to True in production with HTTPS
CSRF_COOKIE_SECURE=False     # Set to True in production with HTTPS

# ============================================================
# PAYMENT PROCESSING (Optional)
# ============================================================
# Stripe for payments
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# ============================================================
# TWILIO (Optional - for SMS features)
# ============================================================
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# REDIS (Optional - for caching & background tasks)
# ============================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ============================================================
# ENVIRONMENT TYPE
# ============================================================
# Options: development, staging, production
ENVIRONMENT=development
